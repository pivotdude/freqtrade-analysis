{
  "name": "freqtrade-analysis",
  "version": "2.0.0",
  "description": "CLI for analyzing Freqtrade SQLite trades and printing markdown reports",
  "type": "module",
  "bin": {
    "freqtrade-analysis": "./bin/freqtrade-analysis.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "dev:hot": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:exe": "bun build src/index.ts --compile --outfile freqtrade-analysis",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "validate:local-release": "bash scripts/validate-local-release.sh",
    "audit:private-artifacts": "bash scripts/audit-private-artifacts.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest"
  }
}
