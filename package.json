{
  "name": "freqtrade-analys",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun src/index.ts",
    "dev:hot": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:exe": "bun build src/index.ts --compile --outfile freqtrade-analys",
    "test": "bun test",
    "validate:local-release": "bash scripts/validate-local-release.sh",
    "audit:private-artifacts": "bash scripts/audit-private-artifacts.sh"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "protobufjs": "^8.0.0"
  }
}
